#!/bin/bash

if [[ $OSTYPE != *darwin* ]]; then
  echo 'ERROR: Must be running macOS.'
  exit 1
fi

if [[ -n $1 ]]; then
  wifi_name=$1
else
  interface=$(route get default | awk '$1 == "interface:" {print $2; exit}')
  wifi_name=$(ipconfig getsummary "$interface" | awk -F ' : ' '$1 ~ /^[[:space:]]+SSID$/ {print $2}')

  if [[ $wifi_name != "<redacted>" ]]; then
    echo "$wifi_name"
    exit
  fi

  cat >&2 << EOT
Wi-Fi name is redacted. To un-redact, run:
  sudo ipconfig sethidewifiinfo 0

Falling back to best guess...
EOT

  wifi_name=$(networksetup -listpreferredwirelessnetworks "$interface" | awk -F'\t' 'NR == 2 {print $2}')
  echo "Wi-Fi name: $wifi_name" >&2
fi

security find-generic-password -wa "$wifi_name"

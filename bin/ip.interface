#!/bin/bash

if [[ $OSTYPE == *darwin* ]]; then
  interface=$(route get default | awk '$1 == "interface:" {print $2; exit}')

  ip_address=$(ifconfig $interface | awk '$1 == "inet" {print $2; exit}')
else
  interface=$(ip route | awk '$1 == "default" {print $5; exit}')

  ip_address=$(ip -4 addr show $interface | awk '$1 == "inet" {print $2; exit}')
  ip_address=${ip_address%.*/}
fi

cat << EOT
Primary Interface: $interface
IP Address:        $ip_address
EOT

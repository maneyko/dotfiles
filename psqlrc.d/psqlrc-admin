-- vim: ft=sql

\set QUIET yes

-- source: http://opensourcedbms.com/dbms/psqlrc-psql-startup-file-for-postgres/
\timing off
SELECT $$
Administrative queries:
        :aliases                -- Show all aliases
        :settings               -- Server settings
        :conninfo               -- Server connections
        :activity               -- Server activity
        :activity_running       -- Server activity of non-idle processes
        :locks                  -- Lock info
        :waits                  -- Waiting queries
        :autovac_runtime        -- Whether autovacuum is running, and how long it has been running
        :last_vacuum            -- Last time the tables were vacuumed and analyzed
        :vac_ready              -- Tables autovacuum sees as eligible for vacuuming
        :largest_objects        -- Largest tables and indexes
        :dbsize                 -- Database size
        :tablesize              -- Tables size
        :uselesscol             -- Useless columns
        :rtsize                 -- Relational table sizes
        :tsize                  -- Table sizes (alternate)
        :row_count              -- Row count for a given table
        :avg_row_size           -- Average row size or all tables in the DB
        :replication_slots      -- Show replication slot information
        :groups                 -- Show groups a user is in
        :users_in_group         -- Show the users in a group
        :tables_without_pks     -- Tables without primary keys
        :tables_in_schema       -- List all tables in the specified schema
        :show_sequence          -- Show information about a specific sequence
        :show_proc              -- Show information about a specific function or procedure
        :index_definition       -- Show the definition of the specified index
        :vacuum_status          -- Show status of vacuums
        :uptime                 -- Server uptime
        :sp                     -- Search path
        :enums                  -- All the enumerated types
        :clear                  -- Clear the terminal screen
        :cls                    -- Clear the terminal screen and output history
        :ll                     -- List the contents of the current directory
        :menu                   -- Help Menu
        \h                      -- Help with SQL commands
        \?                      -- Help with psql commands
$$ AS help_menu \gset
\timing on

\echo -n :help_menu

-- Use when .psqlrc does not load this file automatically:
--\set aliases    '\\i ~/.psqlrc.d/psqlrc-admin'
-- Use when .psqlrc loads this file automatically:
\set aliases        '\\i ~/.psqlrc'
\set settings         'SELECT name, setting,unit,context FROM pg_settings'
\set locks            `cat ~/.psqlrc.d/aliases/admin/locks.sql`
\set conninfo         'SELECT usename, count(*) FROM pg_stat_activity GROUP BY usename;'
\set activity         `cat ~/.psqlrc.d/aliases/admin/activity.sql`
\set activity_running `cat ~/.psqlrc.d/aliases/admin/activity_running.sql`
\set waits            `cat ~/.psqlrc.d/aliases/admin/waits.sql`
\set autovac_runtime  `cat ~/.psqlrc.d/aliases/admin/autovac_runtime.sql`
\set last_vacuum      `cat ~/.psqlrc.d/aliases/admin/last_vacuum_analyze.sql`
\set vac_ready        `cat ~/.psqlrc.d/aliases/admin/vac_ready.sql`
\set largest_objects  `cat ~/.psqlrc.d/aliases/admin/largest_objects.sql`
\set dbsize           `cat ~/.psqlrc.d/aliases/admin/dbsize.sql`
\set tablesize        `cat ~/.psqlrc.d/aliases/admin/tablesize.sql`
\set uselesscol       `cat ~/.psqlrc.d/aliases/admin/uselesscol.sql`
-- rtsize and tsize source: https://gist.github.com/pivaldi/4054440
\set _rtsize           `cat ~/.psqlrc.d/aliases/admin/rtsize.sql`
\set rtsize           `cat ~/.psqlrc.d/aliases/admin/rtsize.sql && echo ";"`
\set tsize            `cat ~/.psqlrc.d/aliases/admin/tsize.sql`
\set row_count        '\\i ~/.psqlrc.d/aliases/admin/row_count.sql'
\set avg_row_size     '\\i ~/.psqlrc.d/aliases/admin/avg_row_size.sql'
\set replication_slots '\\i ~/.psqlrc.d/aliases/admin/replication_slots.sql'
\set groups           '\\i ~/.psqlrc.d/aliases/admin/groups.sql'
\set users_in_group   '\\i ~/.psqlrc.d/aliases/admin/users_in_group.sql'
\set tables_without_pks '\\i ~/.psqlrc.d/aliases/admin/tables_with_primary_keys.sql'
\set tables_in_schema '\\i ~/.psqlrc.d/aliases/admin/tables_in_schema.sql'
\set show_sequence    '\\i ~/.psqlrc.d/aliases/admin/show_sequence.sql'
\set show_proc        '\\i ~/.psqlrc.d/aliases/admin/show_proc.sql'
\set index_definition '\\i ~/.psqlrc.d/aliases/admin/index_definition.sql'
\set vacuum_status    '\\i ~/.psqlrc.d/aliases/admin/vacuum_status.sql'
\set uptime           'SELECT now() - pg_postmaster_start_time() AS uptime;'
\set sp               'SHOW search_path;'
\set enums            `cat ~/.psqlrc.d/aliases/admin/enums.sql`
\set clear            '\\! clear;'
\set cls              '\\! clear && printf "\\033[3J";'
\set ll               '\\! ls -lrt;'

\unset QUIET

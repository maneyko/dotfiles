#!/bin/bash

if [[ $OSTYPE != *darwin* ]]; then
  echo 'ERROR: Must be running macOS'
  exit 1
fi

interface=$(route get default | awk '$1 == "interface:" {print $2; exit}')

# sudo ipconfig sethidewifiinfo 0

wifi_name=$(ipconfig getsummary "$interface" | awk -F ' : ' '$1 ~ /^[[:space:]]+SSID$/ {print $2}')

if [[ $wifi_name != "<redacted>" ]]; then
  echo "$wifi_name"
  exit
fi

cat >&2 << EOT
Wi-Fi name is redacted. To un-redact, run:
  sudo ipconfig sethidewifiinfo 0

Falling back to best guess...

EOT

networksetup -listpreferredwirelessnetworks "$interface" | awk -F'\t' 'NR == 2 {print $2}'

# system_profiler SPAirPortDataType -detailLevel basic -json \
#   | jq -r '
#   .SPAirPortDataType[0].spairport_airport_interfaces
#   | map(select(._name == "en0"))
#   | first
#   | .spairport_current_network_information._name
# '
